# ═══════════════════════════════════════════
# Taranoid - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayıp doldurun
# ═══════════════════════════════════════════

# ── Helius API ──────────────────────────────
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ── Solscan API ─────────────────────────────
SOLSCAN_API_KEY=

# ── Veritabanı (PostgreSQL / Supabase) ─────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taranoid
DATABASE_URL_SUPABASE=

# ── Redis (Upstash) ────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=

# ── Frontend ───────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Monitoring ─────────────────────────────
SENTRY_DSN=

# ── Genel ──────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
