# ══════════════════════════════════════
# Taranoid — .gitignore
# ══════════════════════════════════════

# ── GÜVENLİK: Hassas dosyalar ──
.env
.env.*
!.env.example
*.pem
*.key
*.cert
secrets/

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
env/
*.egg
pip-log.txt

# ── Node.js ──
node_modules/
.next/
out/
.vercel
.turbo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Docker ──
docker-compose.override.yml

# ── Test çıktıları ──
test_results*.json
analysis_result*.json
*_output.txt
coverage/
.coverage
htmlcov/
.pytest_cache/
err.txt

# ── Build çıktıları ──
*.log
*.docx
*.zip
*.tar.gz

# ── Geçici dosyalar ──
tmp/
temp/
*.tmp
sprint1.js
